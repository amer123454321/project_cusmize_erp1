<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="i_tech_product_color_tag_list_view" model="ir.ui.view">
        <field name="name">i.tech.product.color.tag.list.view</field>
        <field name="model">i.tech.product.color.tag</field>
        <field name="arch" type="xml">
            <list string="Orders" class="o_list_view table-striped table-sm">
                <field name="name"/>
                <field name="color" options="{'color_field': 'color'}"/>
            </list>
        </field>
    </record>


    <record id="i_tech_product_color_tag_form_view" model="ir.ui.view">
        <field name="name">i.tech.product.color.tag.form.view</field>
        <field name="model">i.tech.product.color.tag</field>
        <field name="arch" type="xml">
            <form string="Charter">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="color" options="{'color_field': 'color'}"/>
                        </group>
                        <group>

                        </group>
                    </group>
                </sheet>
                <chatter/> 
            </form>
        </field>
    </record>

        
    
    
    <record id="action_i_tech_product_color_tag" model="ir.actions.act_window">
                <field name = "name">Product Color Tag</field>
                <field name = "type">ir.actions.act_window</field>
                <field name = "res_model">i.tech.product.color.tag</field>
                <field name = "view_mode">list,form</field>
                <field name = "domain">[]</field>
                <field name = "context">{}</field>
    </record>

</odoo>
