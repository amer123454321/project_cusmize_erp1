<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>




        
        <record id="i_tech_hide_account_view_account_move_form" model="ir.ui.view">
            <field name="name">i.tech.hide.account.account.move.view.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                
            
            <xpath expr="//field[@name='line_ids']//list//field[@name='debit']" position="before">
                <field name="i_tech_hide_account"  optional="hide"/>
            </xpath>   

            <xpath expr="//field[@name='line_ids']//list//field[@name='debit']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//list//field[@name='credit']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//list//field[@name='amount_currency']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//list//field[@name='balance']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>


            <xpath expr="//field[@name='line_ids']//form//field[@name='debit']" position="before">
                <field name="i_tech_hide_account" invisible="1"/>
            </xpath>   

            <xpath expr="//field[@name='line_ids']//form//field[@name='debit']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//form//field[@name='credit']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//form//field[@name='amount_currency']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']//form//field[@name='balance']" position="attributes">
                <attribute name="invisible">i_tech_hide_account</attribute>
            </xpath>



            </field>
        </record>


