        <record id="i_tech_account_move_line_view_kanban_inherit_hide_amount" model="ir.ui.view">
            <field name="name">i.tech.account.move.line.kanban.inherit.hide.amount</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.account_move_line_view_kanban"/>
            <field name="arch" type="xml">

                 <xpath expr="//kanban" position="inside">
                    <field name="i_tech_hide_account"/>
                </xpath>


                <xpath expr="//div[@class='col-6 text-end']" position="attributes">
                    <attribute name="t-if">
                        not record.i_tech_hide_account.raw_value
                    </attribute>
                </xpath>

            </field>
        </record>



