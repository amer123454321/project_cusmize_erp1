<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="i_tech_qemat_view_users_form_inherit" model="ir.ui.view">
            <field name="name">i.tech.qemat.view.users.form.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='preferences']" position="after">
                    <page string="Additional access rights">
                        <group >
                            <group string="Partners">
                                <field name="allowed_partner_types" widget="many2many_tags"/>
                            </group>
                            <group string="Accounting">
                                <field name="accounting_lock"/>
                                <field name="accounting_lock_date" invisible="accounting_lock != True"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>