   <record id="sale_order_form_show_prices_btn" model="ir.ui.view">
        <field name="name">sale.order.form.show.prices.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- نضيف الزر في شريط الأزرار -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_show_prices"
                    type="object"
                    string="Show Prices"
                    class="btn-primary"
                />
            </xpath>

        </field>
    </record>

    </data>

</odoo>
