<?xml version="1.0" encoding="utf-8"?>
<odoo>
 
    <record id="i_tech_base_product_template_form" model="ir.ui.view">
        <field name="name">i.tech.base.product.template.view.form.inherit.base</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="i_tech_use_color_tag" widget="boolean_toggle"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Location Tags">
                    <field name="i_tech_location_tag_ids">
                        <list string="Location Tags" sample="1" editable="bottom">
                            <field name="product_id" column_invisible="1" force_save="1"/>
                            <field name="location_id" force_save="1"/>
                            <field name="tag_ids" widget="many2many_tags" domain="[('location_id','=',location_id)]" context="{'default_location_id': location_id}"/>
                            
    
                        </list>
                    </field>

                </page>
            </xpath>
        </field>
    </record>


    

    
</odoo>
