<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="i_tech_partner_type_rule_users" model="ir.rule">
        <field name="name">Partner Type Restrict on Users</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">['|',('i_tech_partner_type_id', 'in', user.allowed_partner_types.ids),('i_tech_partner_type_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('i_tech_royal_rahmani_base.i_tech_user_partner_type_restriction_group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="active" eval="True"/>
    </record>
    




</odoo>
