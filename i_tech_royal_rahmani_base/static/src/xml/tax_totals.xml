<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <xpath expr="//tr[1]" position="before">
            <tr t-if="totals.amount_before_discount_currency">
                <td class="o_td_label">
                        <label class="o_form_label o_tax_total_label">Amount Before Discount</label>
                </td>
                <td class="o_list_monetary">
                        <span
                            name="amount_before_discount_currency"
                            t-att-class="{'oe_subtotal_footer_separator': totals.has_tax_groups}"
                            t-out="formatMonetary(totals.amount_before_discount_currency)"
                            style="font-size: 1.3em; font-weight: bold; white-space: nowrap;"
                        />
                </td>
            </tr>
        </xpath>
        <xpath expr="//tr[1]" position="after">
            <tr t-if="totals.discount_amount_currency">
                <td class="o_td_label">
                        <label class="o_form_label o_tax_total_label">Discount Amount</label>
                </td>
                <td class="o_list_monetary">
                        <span
                            name="discount_amount_currency"
                            t-att-class="{'oe_subtotal_footer_separator': totals.has_tax_groups}"
                            t-out="formatMonetary(totals.discount_amount_currency)"
                            style="font-size: 1.3em; font-weight: bold; white-space: nowrap;"
                        />
                </td>
            </tr>
        </xpath>
    </t>
</templates>
