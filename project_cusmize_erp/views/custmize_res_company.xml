<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Company Business Policy Tab -->
    <!-- ============================= -->

    <record id="view_company_form_smart_business" model="ir.ui.view">
        <field name="name">res.company.form.smart.business.control</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">

            <!-- نحط قسم جديد داخل Settings -->
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Business Control">

                    <group string="Invoice Policy">
                        <field name="invoice_lock_days"/>
                    </group>

                    <group string="Sales Policy">
                        <field name="max_discount_without_approval"/>
                    </group>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
