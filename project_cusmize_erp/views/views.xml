</style>
<h3 style="text-align:center;">

فاتورة المبيعات
</h3>

<div class="container" dir="rtl">
    <div class="d-flex justify-content-between p-2 align-items-center mb-4">
        <div class="d-flex align-items-center gap-2">
            <span>التاريخ :</span>
            20/9/1997
        </div>

        <div class="d-flex align-items-center gap-2">

<span>الرقم :</span>
<span>0785555555</span>
        </div>
