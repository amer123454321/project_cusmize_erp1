            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">report_invoice.i_tech_property_report_template_applicant</field>
            <field name="report_file">report_invoice.i_tech_property_report_template_applicant</field>
            <field name="binding_model_id" ref="model_account_move"/>
            <field name="binding_type">report</field>
        </record>


