</div>



<div class="container" dir="rtl" style="margin-top:10px;">

    <div class="row mb-2">

        <div class="col-6 p-2">
            <strong>إسم السائق :</strong>
            <span style="border-bottom:1px dotted #000; display:inline-block; width:70%;">
                <t t-esc="o.invoice_user_id.name"/>
            </span>
        </div>

        <div class="col-6 p-2">
            <strong>نوع ورقم السيارة :</strong>
            <span style="border-bottom:1px dotted #000; display:inline-block; width:70%;">
                <t t-esc="o.ref"/>
            </span>
        </div>

    </div>

    <div class="row">

        <div class="col-6 p-2">
            <strong>العنوان :</strong>
            <span style="border-bottom:1px dotted #000; display:inline-block; width:70%;">
                <t t-esc="o.partner_id.street"/>
            </span>
        </div>

        <div class="col-6 p-2">
            <strong>إلى السيد :</strong>
            <span style="border-bottom:1px dotted #000; display:inline-block; width:70%;">
                <t t-esc="o.partner_id.name"/>
            </span>
        </div>

    </div>

</div>




<div class="page">
 <div>


<div class="oe_structure"/>
<t t-set="display_discount" t-value="any(l.discount for l in o.invoice_line_ids)"/>
<table class="o_has_total_table table o_main_table table-borderless mb-0" name="invoice_line_tabledirection: rtl;border:1px dashed #000 ;        border: 1px dashed #000 !important;
">
    <thead style= "border: 1px dashed #000 !important;    display: table-header-group;">
        <tr>
            <th class="text-center"><span>رمز المادة</span></th>
            <th class="text-center"><span>الإجمالي</span></th>
              <th t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>الإفرادي</span></th>

            <th t-attf-class="text-center text-nowrap {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>الواحدة</span></th>
            <th t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>العدد</span></th>
            <th t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>إسم الماده </span></th>

            <!--<th t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span> رمز الماده</span></th>-->
            <th class="text-center"><span>#</span></th>

        </tr>
    </thead>

<tbody class="invoice_tbody">
    <t t-set="current_subtotal" t-value="0"/>
    <t t-set="current_total" t-value="0"/>
    <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
    <t t-set="product_index" t-value="0"/>

    <t t-foreach="lines" t-as="line" t-foreach-index="line_index">

        <tr t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">

            <t t-if="line.display_type == 'product'">
                <t t-set="product_index" t-value="product_index + 1"/>
                <t t-set="current_total" t-value="current_total + (line.price_total or 0)"/>

                <td class="o_td_quantity text-center"><span t-field="line.product_id.default_code"/></td>
                <td class="o_td_quantity text-center"><span t-field="line.name"/></td>
                <td class="o_td_quantity text-center"><span t-field="line.product_uom_id"/></td>
                <td class="o_td_quantity text-center"><span t-field="line.quantity"/></td>
                <td class="o_td_quantity text-center"><span t-field="line.price_unit"/></td>
                <td class="o_td_quantity text-center"><span t-field="line.price_subtotal"/></td>
                                <td class="o_td_quantity text-center"><t t-esc="product_index"/></td>


                <t t-set="current_subtotal" t-value="current_subtotal + (line.price_subtotal or 0)"/>
            </t>

            <t t-elif="line.display_type == 'line_section'">
                <td colspan="99"><span t-field="line.name" t-options="{'widget': 'text'}"/></td>
                <t t-set="current_section" t-value="line"/>
                <t t-set="current_subtotal" t-value="0"/>
            </t>

            <t t-elif="line.display_type == 'line_note'">
                <td colspan="99"><span t-field="line.name" t-options="{'widget': 'text'}"/></td>
            </t>

        </tr>

        <t t-if="current_section and ((line_index + 1 == len(lines)) or lines[line_index + 1].display_type == 'line_section')">
            <tr class="is-subtotal text-end">
                <td colspan="99">
                    <strong class="mr16">Subtotal</strong>
                    <span t-out="current_subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                </td>
            </tr>
        </t>

    </t>

    <tr>
        <td colspan="1" style="border:none; border-bottom:1px dashed #000;"></td>
        <td style="font-weight:bold; text-align:center; border:none; border-bottom:1px dashed #000">: الخصم</td>
        <td colspan="4" style="border-bottom:1px dashed #000;"/>
    </tr>

    <tr>
        <td colspan="1" style="border:none; border-bottom:1px dashed #000"></td>
        <td style="font-weight:bold; text-align:center; border:none; border-bottom:1px dashed #000;">: المجموع</td>
        <td colspan="5" style="border-bottom:1px dashed #000;"/>
    </tr>

    <tr>
        <td colspan="1" style="border:none;"/>
        <td style="border:none; font-weight:bold; text-align:center;">: الصافي رقما</td>
        <td colspan="4" style="border:none;border-left:1px dashed #000 "/>
        <td style=" !important border:none; border-left:1px dashed #000 !important; font-weight:bold; text-align:right;" colspan="1" >: الصافي تقطيعا </td>
    </tr>
</tbody>
</table>

