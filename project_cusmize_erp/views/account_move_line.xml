<odoo>
    <record id="account_move_line_form_no_default_account" model="ir.ui.view">
        <field name="name">move.line.no.default.account</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>

        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_id']" position="attributes">
                <attribute name="context">{'default_account_id': False}</attribute>
            </xpath>
        </field>
    </record>
</odoo>