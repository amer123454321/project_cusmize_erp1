<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================= -->
    <!-- SALES GROUPS -->
    <!-- ========================= -->

    <record id="group_advanced_sales_user" model="res.groups">
        <field name="name">Advanced Sales User</field>
        <field name="category_id" ref="base.module_category_sales"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_sales_team_manager_custom" model="res.groups">
        <field name="name">Sales Team Manager (Advanced)</field>
        <field name="category_id" ref="base.module_category_sales"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
    </record>

    <!-- ========================= -->
    <!-- ACCOUNTING GROUPS -->
    <!-- ========================= -->

    <record id="group_finance_controller" model="res.groups">
        <field name="name">Finance Controller</field>
        <field name="category_id" ref="base.module_category_accounting"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="group_accounting_director_custom" model="res.groups">
        <field name="name">Accounting Director</field>
        <field name="category_id" ref="base.module_category_accounting"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>

    <!-- ========================= -->
    <!-- FULL BUSINESS ADMIN -->
    <!-- ========================= -->

    <record id="group_business_admin" model="res.groups">
        <field name="name">Business Administrator</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_system')),
            (4, ref('sales_team.group_sale_manager')),
            (4, ref('account.group_account_manager'))
        ]"/>
    </record>

</odoo>
